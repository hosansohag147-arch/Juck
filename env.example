# Configuration for Gemini API Keys
# You can set one or multiple API keys using variables like below:
GEMINI_API_KEY_1="your_first_gemini_api_key_here"
GEMINI_API_KEY_2="your_second_gemini_api_key_here"
GEMINI_API_KEY_3="your_third_gemini_api_key_here"

# (Fallback option if available)
GEMINI_API_KEY="your_fallback_gemini_api_key_here"

# Example Railway App URL:
APP_URL="https://your-railway-app-name.up.railway.app"